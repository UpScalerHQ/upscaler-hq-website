<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/png" href="https://assets.cdn.filesafe.space/YapgZpEE87fnHWFSfSRe/media/69fb0886247534830e865fd1.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Before Your Strategy Call — UpScaler HQ</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:      #070b10;
      --dark:       #0d1520;
      --surface:    #111d2c;
      --surface2:   #162236;
      --border:     rgba(0,210,220,0.1);
      --border2:    rgba(0,210,220,0.18);
      --cyan:       #00d4dc;
      --cyan-dim:   #00a8b0;
      --teal:       #0891b2;
      --teal-dim:   #0e7490;
      --blue:       #1e5fa8;
      --white:      #f0f8ff;
      --text-sub:   rgba(200,230,240,0.68);
      --text-muted: rgba(150,200,220,0.42);
      --red:        #f87171;
      --grad-text: linear-gradient(135deg, #00d4dc 0%, #0891b2 60%, #1e5fa8 100%);
      --grad-bg:   linear-gradient(160deg, #0d1520 0%, #070b10 60%, #091520 100%);
      --grad-cta:  linear-gradient(135deg, #00d4dc, #0891b2);
      --grad-mesh: radial-gradient(ellipse 80% 60% at 70% 40%, rgba(8,145,178,0.18) 0%, transparent 65%),
                   radial-gradient(ellipse 50% 40% at 20% 70%, rgba(0,212,220,0.08) 0%, transparent 60%);
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Manrope', sans-serif;
      font-weight: 400;
      line-height: 1.7;
      overflow-x: hidden;
    }



    /* VIDEO PLACEHOLDER */
    .video-placeholder {
      width: 100%;
      aspect-ratio: 16/9;
      background: var(--surface2);
      border: 2px dashed rgba(0,212,220,0.25);
      border-radius: 14px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.8rem;
      color: var(--text-muted);
      font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      position: relative; overflow: hidden;
      transition: border-color 0.2s;
    }
    .video-placeholder:hover { border-color: rgba(0,212,220,0.45); }
    .video-placeholder::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(8,145,178,0.08) 0%, transparent 70%);
    }
    .video-play-icon {
      width: 64px; height: 64px;
      background: rgba(0,212,220,0.1);
      border: 1px solid rgba(0,212,220,0.3);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem;
      position: relative; z-index: 1;
    }
    .video-placeholder-label { position: relative; z-index: 1; }

    /* HERO */
    .hero {
      min-height: 80vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 5rem 2rem 5rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: var(--grad-mesh);
      pointer-events: none;
    }
    #heroBgCanvas {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      z-index: 0; pointer-events: none;
    }
    .hero-inner { position: relative; z-index: 2; max-width: 900px; }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(0,212,220,0.08);
      border: 1px solid rgba(0,212,220,0.25);
      border-radius: 100px;
      padding: 0.35rem 1rem;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--cyan); margin-bottom: 2rem;
      opacity: 0; transform: translateY(10px);
      animation: fadeUp 0.6s ease 0.2s forwards;
    }
    .badge-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--cyan); box-shadow: 0 0 6px var(--cyan);
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1;}50%{opacity:0.4;} }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-headline {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2.2rem, 5vw, 4rem);
      font-weight: 800;
      line-height: 1.12;
      letter-spacing: -0.01em;
      margin-bottom: 1.4rem;
      opacity: 0; transform: translateY(20px);
      animation: fadeUp 0.8s ease 0.4s forwards;
    }
    .grad-text {
      background: var(--grad-text);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    .hero-sub {
      font-size: 1rem; color: var(--text-sub);
      max-width: 580px; margin: 0 auto 2.4rem;
      line-height: 1.8; font-weight: 400;
      opacity: 0; transform: translateY(14px);
      animation: fadeUp 0.7s ease 0.6s forwards;
    }

    .call-confirm-card {
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 16px;
      padding: 2rem 2.4rem;
      max-width: 520px;
      margin: 0 auto 2rem;
      display: flex; align-items: center; gap: 1.4rem;
      text-align: left;
      opacity: 0; transform: translateY(14px);
      animation: fadeUp 0.7s ease 0.8s forwards;
    }
    .call-icon {
      width: 52px; height: 52px; flex-shrink: 0;
      background: rgba(0,212,220,0.1);
      border: 1px solid rgba(0,212,220,0.25);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
    }
    .call-confirm-label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cyan); margin-bottom: 0.25rem; }
    .call-confirm-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 800; margin-bottom: 0.2rem; }
    .call-confirm-sub { font-size: 0.78rem; color: var(--text-sub); }

    .btn-primary {
      background: var(--grad-cta);
      color: var(--black);
      font-family: 'Manrope', sans-serif;
      font-size: 0.92rem; font-weight: 800;
      letter-spacing: 0.03em;
      padding: 1rem 2.6rem;
      border: none; cursor: pointer;
      text-decoration: none;
      border-radius: 8px;
      display: inline-flex; align-items: center; gap: 0.6rem;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 0 28px rgba(0,212,220,0.25);
      opacity: 0; animation: fadeUp 0.7s ease 1s forwards;
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); box-shadow: 0 0 40px rgba(0,212,220,0.4); }
    .btn-primary-static {
      background: var(--grad-cta);
      color: var(--black);
      font-family: 'Manrope', sans-serif;
      font-size: 0.92rem; font-weight: 800;
      letter-spacing: 0.03em;
      padding: 1rem 2.6rem;
      border: none; cursor: pointer;
      text-decoration: none;
      border-radius: 8px;
      display: inline-flex; align-items: center; gap: 0.6rem;
      transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 0 28px rgba(0,212,220,0.25);
    }
    .btn-primary-static:hover { opacity: 0.88; transform: translateY(-2px); box-shadow: 0 0 40px rgba(0,212,220,0.4); }

    .guarantee-note {
      margin-top: 1.2rem;
      font-size: 0.72rem; color: var(--text-muted);
      letter-spacing: 0.06em;
      display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      opacity: 0; animation: fadeUp 0.6s ease 1.2s forwards;
    }
    .guarantee-note::before { content: '✓'; color: var(--cyan); }

    /* SECTIONS */
    .section { padding: 6rem 3rem; max-width: 1100px; margin: 0 auto; }
    .section-eyebrow {
      font-size: 0.68rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--cyan); margin-bottom: 0.8rem;
      display: flex; align-items: center; gap: 0.7rem;
    }
    .section-eyebrow::before { content: ''; display: block; width: 24px; height: 1px; background: var(--cyan); }
    .section-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 800; line-height: 1.1;
      margin-bottom: 1rem; letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 0.92rem; color: var(--text-sub);
      max-width: 520px; margin-bottom: 3rem; line-height: 1.8;
    }

    /* DIVIDER */
    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0;
    }

    /* WHAT TO EXPECT */
    .expect-wrap {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 6rem 3rem;
    }
    .expect-inner { max-width: 1100px; margin: 0 auto; }
    .expect-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
      margin-top: 2.5rem;
    }
    .expect-card {
      background: var(--dark); padding: 2.2rem 2rem;
      transition: background 0.2s;
      position: relative; overflow: hidden;
    }
    .expect-card::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--grad-cta);
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s ease;
    }
    .expect-card:hover { background: var(--surface2); }
    .expect-card:hover::after { transform: scaleX(1); }
    .expect-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2.4rem; font-weight: 800;
      background: var(--grad-text);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      opacity: 0.35; line-height: 1; margin-bottom: 0.8rem;
    }
    .expect-title { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.5rem; }
    .expect-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.7; }

    /* AUTHORITY — who am I */
    .authority-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: center;
      margin-top: 0;
    }
    .authority-img-wrap {
      position: relative;
    }
    .authority-img-placeholder {
      width: 100%; aspect-ratio: 4/5;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 20px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.8rem;
      color: var(--text-muted);
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      position: relative; overflow: hidden;
    }
    .authority-img-placeholder::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 30%, rgba(8,145,178,0.12) 0%, transparent 70%);
    }
    .authority-img-placeholder-icon { font-size: 3rem; opacity: 0.3; }
    .authority-badge-float {
      position: absolute; bottom: -1rem; right: -1rem;
      background: var(--dark);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: 1rem 1.4rem;
      text-align: center;
    }
    .authority-badge-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.8rem; font-weight: 800;
      background: var(--grad-text);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1;
    }
    .authority-badge-label { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.2rem; }
    .authority-points { list-style: none; display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
    .authority-points li {
      display: flex; align-items: flex-start; gap: 0.85rem;
      font-size: 0.88rem; color: var(--text-sub); line-height: 1.6;
    }
    .authority-points li::before { content: '✓'; color: var(--cyan); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

    /* STATS ROW */
    .stats-bar {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      padding: 3rem;
    }
    .stats-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
    }
    .stat-item {
      background: var(--dark); padding: 2rem;
      text-align: center;
    }
    .stat-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2.4rem; font-weight: 800;
      background: var(--grad-text);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1; margin-bottom: 0.4rem;
    }
    .stat-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }

    /* TESTIMONIALS */
    .testimonials-grid {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem; margin-top: 2.5rem;
    }
    .testimonial-card {
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2.4rem 2.2rem;
      position: relative;
      transition: border-color 0.2s, transform 0.2s;
    }
    .testimonial-card:hover { border-color: var(--border2); transform: translateY(-2px); }
    .testimonial-card::before {
      content: '\201C';
      position: absolute; top: -0.4rem; left: 1.6rem;
      font-size: 5rem; line-height: 1;
      color: var(--cyan); opacity: 0.12;
      font-family: 'Plus Jakarta Sans', sans-serif;
      pointer-events: none;
    }
    .testimonial-card.featured {
      grid-column: 1 / -1;
      background: linear-gradient(135deg, rgba(0,212,220,0.04) 0%, rgba(8,145,178,0.04) 100%);
      border-color: var(--border2);
    }
    .test-stars { color: var(--cyan); font-size: 0.9rem; letter-spacing: 0.12em; margin-bottom: 1rem; }
    .test-quote {
      font-size: 0.92rem; color: var(--white);
      line-height: 1.8; font-style: italic;
      margin-bottom: 1.6rem;
    }
    .test-quote.large { font-size: 1.05rem; }
    .test-divider { width: 36px; height: 2px; background: var(--grad-cta); border-radius: 2px; margin-bottom: 1.2rem; }
    .test-meta { display: flex; align-items: center; gap: 0.9rem; }
    .test-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--surface2);
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem; font-weight: 800;
      color: var(--cyan); flex-shrink: 0;
    }
    .test-name { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 0.88rem; }
    .test-biz { font-size: 0.65rem; color: var(--cyan); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; margin-top: 0.1rem; }
    .test-result-tag {
      margin-left: auto; flex-shrink: 0;
      display: inline-flex; align-items: center; gap: 0.4rem;
      background: rgba(0,212,220,0.08);
      border: 1px solid rgba(0,212,220,0.2);
      border-radius: 100px;
      padding: 0.25rem 0.75rem;
      font-size: 0.65rem; font-weight: 700; color: var(--cyan);
    }

    /* RESULTS — before/after */
    .results-grid {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem; margin-top: 2.5rem;
    }
    .result-card {
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem 2.2rem;
      transition: border-color 0.2s, transform 0.2s;
    }
    .result-card:hover { border-color: var(--border2); transform: translateY(-2px); }
    .result-biz {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--cyan); margin-bottom: 0.6rem;
    }
    .result-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem; font-weight: 800; margin-bottom: 1.2rem;
    }
    .arrow-box {
      background: rgba(0,212,220,0.05);
      border: 1px solid rgba(0,212,220,0.12);
      border-radius: 10px;
      padding: 1.2rem 1.4rem;
      margin-bottom: 1.2rem;
    }
    .arrow-row {
      display: grid; grid-template-columns: 1fr 24px 1fr;
      align-items: center; gap: 0.5rem;
      margin-bottom: 0.75rem;
    }
    .arrow-row:last-child { margin-bottom: 0; }
    .arrow-label { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.2rem; }
    .arrow-from { color: var(--red); font-weight: 700; font-size: 0.85rem; line-height: 1.3; }
    .arrow-to   { color: var(--cyan); font-weight: 700; font-size: 0.85rem; line-height: 1.3; }
    .arrow-icon { color: var(--cyan); font-size: 1rem; text-align: center; }
    .result-note { font-size: 0.75rem; color: var(--text-muted); line-height: 1.6; }

    /* OBJECTIONS / FAQ */
    .faq-wrap {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 6rem 3rem;
    }
    .faq-inner { max-width: 1100px; margin: 0 auto; }
    .faq-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1rem; margin-top: 2.5rem;
    }
    .faq-item {
      background: var(--dark);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.8rem 2rem;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .faq-item:hover { border-color: var(--border2); }
    .faq-item.open { border-color: var(--border2); }
    .faq-q {
      font-weight: 700; font-size: 0.9rem;
      display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;
      color: var(--white);
    }
    .faq-q-icon {
      color: var(--cyan); font-size: 1.2rem; flex-shrink: 0;
      transition: transform 0.3s ease; line-height: 1;
    }
    .faq-item.open .faq-q-icon { transform: rotate(45deg); }
    .faq-a {
      font-size: 0.82rem; color: var(--text-sub); line-height: 1.8;
      max-height: 0; overflow: hidden;
      transition: max-height 0.4s ease, margin-top 0.3s ease;
      margin-top: 0;
    }
    .faq-item.open .faq-a { max-height: 700px; margin-top: 1rem; }

    /* CALL AGENDA */
    .agenda-steps {
      display: flex; flex-direction: column; gap: 0;
      margin-top: 2.5rem;
      border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
    }
    .agenda-step {
      display: grid; grid-template-columns: 60px 1fr;
      gap: 0; align-items: stretch;
      border-bottom: 1px solid var(--border);
      background: var(--dark);
      transition: background 0.2s;
    }
    .agenda-step:last-child { border-bottom: none; }
    .agenda-step:hover { background: var(--surface2); }
    .agenda-time {
      background: rgba(0,212,220,0.04);
      border-right: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; font-weight: 700; color: var(--cyan);
      letter-spacing: 0.06em; text-transform: uppercase;
      writing-mode: vertical-rl; text-orientation: mixed;
      padding: 1.2rem 0;
    }
    .agenda-content { padding: 1.4rem 1.8rem; }
    .agenda-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.25rem; }
    .agenda-desc { font-size: 0.78rem; color: var(--text-muted); line-height: 1.6; }

    /* FINAL CTA */
    .final-cta {
      padding: 8rem 3rem; text-align: center;
      position: relative; overflow: hidden;
      border-top: 1px solid var(--border);
    }
    .final-cta::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(8,145,178,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .final-cta::after {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,212,220,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,220,0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }
    .final-cta-inner { position: relative; z-index: 2; }
    .final-cta h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      font-weight: 800; line-height: 1.1;
      max-width: 720px; margin: 0 auto 1.4rem;
    }
    .final-cta p { font-size: 0.95rem; color: var(--text-sub); max-width: 460px; margin: 0 auto 2.5rem; }
    .cta-trust-row {
      display: flex; align-items: center; justify-content: center; gap: 2rem;
      margin-top: 2rem; flex-wrap: wrap;
    }
    .cta-trust-item {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.72rem; color: var(--text-muted);
      font-weight: 500;
    }
    .cta-trust-item::before { content: '✓'; color: var(--cyan); }

    /* FOOTER */
    footer {
      padding: 1.8rem 3rem;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 1rem;
      background: var(--dark);
