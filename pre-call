<script>
  /* HERO CANVAS — constellation network */
  (function() {
    var canvas = document.getElementById('heroBgCanvas');
    var hero = document.querySelector('.hero');
    if (!hero || !canvas) return;
    var ctx = canvas.getContext('2d');
    var W, H;
    function resize() {
      W = canvas.width  = hero.offsetWidth;
      H = canvas.height = hero.offsetHeight;
      nodes.forEach(function(n) { n.x = Math.random() * W; n.y = Math.random() * H; });
    }
    var COUNT = 55, CONNECT_DIST = 160;
    var palette = [[0,212,220],[8,145,178],[30,95,168],[0,160,180]];
    var nodes = [];
    for (var i = 0; i < COUNT; i++) {
      var bright = Math.random() < 0.18;
      nodes.push({
        x: Math.random() * (window.innerWidth || 1200),
        y: Math.random() * 700,
        vx: (Math.random()-0.5)*0.18, vy: (Math.random()-0.5)*0.18,
        r: bright ? 1.8+Math.random()*1.4 : 0.6+Math.random()*0.9,
        col: palette[Math.floor(Math.random()*palette.length)],
        opacity: bright ? 0.75+Math.random()*0.25 : 0.22+Math.random()*0.28,
        phase: Math.random()*Math.PI*2, phaseSpeed: 0.008+Math.random()*0.010
      });
    }
    resize();
    window.addEventListener('resize', resize);
    function draw() {
      ctx.clearRect(0,0,W,H);
      nodes.forEach(function(n) {
        n.x+=n.vx; n.y+=n.vy;
        if(n.x<-10)n.x=W+10; if(n.x>W+10)n.x=-10;
        if(n.y<-10)n.y=H+10; if(n.y>H+10)n.y=-10;
        n.phase+=n.phaseSpeed;
      });
      for(var i=0;i<nodes.length;i++){
        for(var j=i+1;j<nodes.length;j++){
          var dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y;
          var dist=Math.sqrt(dx*dx+dy*dy);
          if(dist<CONNECT_DIST){
            var alpha=(1-dist/CONNECT_DIST)*0.18;
            var c=nodes[i].col;
            ctx.beginPath(); ctx.moveTo(nodes[i].x,nodes[i].y); ctx.lineTo(nodes[j].x,nodes[j].y);
            ctx.strokeStyle='rgba('+c[0]+','+c[1]+','+c[2]+','+alpha+')';
            ctx.lineWidth=0.7; ctx.stroke();
          }
        }
      }
      nodes.forEach(function(n){
        var flicker=0.72+0.28*Math.sin(n.phase), a=n.opacity*flicker;
        if(n.r>1.5){
          var halo=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*5);
          halo.addColorStop(0,'rgba('+n.col[0]+','+n.col[1]+','+n.col[2]+','+(a*0.5)+')');
          halo.addColorStop(1,'rgba('+n.col[0]+','+n.col[1]+','+n.col[2]+',0)');
          ctx.beginPath(); ctx.arc(n.x,n.y,n.r*5,0,Math.PI*2);
          ctx.fillStyle=halo; ctx.fill();
        }
        ctx.beginPath(); ctx.arc(n.x,n.y,n.r,0,Math.PI*2);
        ctx.fillStyle='rgba('+n.col[0]+','+n.col[1]+','+n.col[2]+','+a+')'; ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();

  /* SCROLL REVEALS */
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) { entry.target.classList.add('in-view'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal, .reveal-card, .reveal-fade').forEach(function(el) { observer.observe(el); });
  })();

  /* COUNTER ANIMATION */
  (function() {
    var counters = document.querySelectorAll('.stat-num[data-target]');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.getAttribute('data-target'));
        var suffix = el.getAttribute('data-suffix') || '+';
        var duration = 1600, start = null;
        function step(ts) {
          if (!start) start = ts;
          var progress = Math.min((ts - start) / duration, 1);
          var ease = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(ease * target).toLocaleString() + (progress < 1 ? '' : suffix);
          if (progress < 1) requestAnimationFrame(step);
          else el.textContent = target.toLocaleString() + suffix;
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });
    counters.forEach(function(c) { observer.observe(c); });
  })();

  /* FAQ ACCORDION */
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.querySelector('.faq-q').addEventListener('click', function() {
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(function(o) { o.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

